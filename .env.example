# Production / preview: required. Use your deployed API origin (no trailing slash, no /api prefix).
# VITE_API_BASE_URL=https://your-api.vercel.app
#
# Local dev: leave unset to use same-origin /api (Vite proxies to http://localhost:5000, avoids CORS).
# Or set explicitly to call the API directly: VITE_API_BASE_URL=http://localhost:5000
#
# Vercel: set on the user-frontend project and redeploy so the value is baked into the build.
VITE_API_BASE_URL=
